# Supabase configuration
# Copy this file to `.env.local` for local development and fill in your project values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional demo login accounts for environments where signup should be avoided.
VITE_DEMO_INVESTOR_EMAIL=demo-investor@example.com
VITE_DEMO_INVESTOR_PASSWORD=change-me
VITE_DEMO_STARTUP_EMAIL=demo-startup@example.com
VITE_DEMO_STARTUP_PASSWORD=change-me

# Local-only backend utility script variables. Do not expose the service role
# key in frontend code or Vite-prefixed env vars.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DEMO_INVESTOR_EMAIL=demo-investor@bathra.demo
DEMO_INVESTOR_PASSWORD=BathraDemo123!
DEMO_STARTUP_EMAIL=demo-startup@bathra.demo
DEMO_STARTUP_PASSWORD=BathraDemo123!
DEMO_ADMIN_EMAIL=demo-admin@bathra.demo
DEMO_ADMIN_PASSWORD=BathraAdmin123!
DEMO_STARTUP_VALUATION=2000000
DEMO_STARTUP_FUNDING_GOAL=500000
DEMO_PENDING_OFFER_AMOUNT=50000
SEED_PENDING_PAPER_OFFER=true
